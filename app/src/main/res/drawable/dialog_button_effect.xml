<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/dialog_button_ripple"> <!-- This is the ripple color -->
    <item android:id="@android:id/mask">
        <!-- The mask defines the ripple's shape (e.g., a rectangle with corners) -->
        <shape android:shape="rectangle">
            <solid android:color="@android:color/white" />
            <!-- Add corner radius here if needed -->
            <corners android:radius="16dp" />
        </shape>
    </item>
    <!-- This item defines the button's normal background color/drawable -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/background_color" />
            <!-- Add corner radius here to match the mask -->
            <corners android:radius="16dp" />
        </shape>
    </item>
</ripple>